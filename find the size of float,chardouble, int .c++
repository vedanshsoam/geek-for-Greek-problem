#include<iostream>
using namespace std;

int main()
{
    cout<<"Size of float is "<<sizeof(float)<<" bytes"<<endl;
    cout<<"Size of char is "<<sizeof(char)<<" bytes"<<endl;
    cout<<"Size of double is "<<sizeof(double)<<" bytes"<<endl;
    cout<<"Size of int is "<<sizeof(int)<<" bytes"<<endl;
    return 0;
}